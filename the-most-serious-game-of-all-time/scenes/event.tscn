[sub_resource type="GDScript" id="GDScript_7bopq"]
script/source = "extends Label

func _ready() -> void {
	text = ([
		\"Another foe, vanquished...\",
		\"Can you hear their souls, calling?\",
		\"They'll be back soon enough...\",
		\"Oh, the fight, a frantic work of art. Your pain, your burden, to flatten it, their heart...\",
		\"How much more longer can you endure?\",
		\"It's all uphill from here.\",
		\"Just one more fight, one more spin, surely then you'll win...\",
		\"99% of gamblers quit before they escape Tartarus...\"
	] as Array[String]).pick_random()
}
"

[sub_resource type="GDScript" id="GDScript_wpb14"]
script/source = "extends Button

@export var cam: Camera2D
var already_pressed := false

func _pressed() -> void {
	if not already_pressed {
		cam.position.y += get_viewport_rect().size.y
		already_pressed = true
	}
}
"

[sub_resource type="LabelSettings" id="LabelSettings_wpb14"]
font_size = 32

[sub_resource type="LabelSettings" id="LabelSettings_jtw3a"]
font_color = Color(1, 1, 1, 0.654902)

[sub_resource type="GDScript" id="GDScript_jtw3a"]
script/source = "extends Button

@export var evman: EventManager

func _pressed() -> void {
	var event := evman.event
	GamestateManager.check_combat_result()
	GamestateManager.encounter_enemy()
	GamestateManager.previous_event = event
}
"

