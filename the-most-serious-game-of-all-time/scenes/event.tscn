[node name="Event" type="Control" unique_id=1331712075 node_paths=PackedStringArray("main_title", "main_desc", "options", "result", "effect", "audioplayer", "cam")]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_jtw3a")
main_title = NodePath("EventDisplay/VBoxContainer/Choice/PanelContainer/MarginContainer/VBoxContainer/Title")
main_desc = NodePath("EventDisplay/VBoxContainer/Choice/PanelContainer/MarginContainer/VBoxContainer/Description")
options = NodePath("EventDisplay/VBoxContainer/Choice/PanelContainer/MarginContainer/VBoxContainer/Options")
result = NodePath("EventDisplay/VBoxContainer/Result/PanelContainer/MarginContainer/VBoxContainer/Description")
effect = NodePath("EventDisplay/VBoxContainer/Result/PanelContainer/MarginContainer/VBoxContainer/Effect")
audioplayer = NodePath("AudioStreamPlayer")
cam = NodePath("Camera2D")
titles = Array[String](["THE STARVED MAN", "THE BOY", "THE WEDDED WOMAN", "THE LYREMAN", "THE ARROW HEELED WARRIOR", "THE VOICES OF THE FORGOTTEN", "THE HARDENED WORLD", "THE FOOTPRINT"])
descriptions = Array[String](["You stumble upon a thin, starving man, grasping at an apple above him. Yet despite him clawing and clawing, the apple remains just out of reach.

“I know I can never reach it.” The starved man says. “But I try all the same.”", "You come across a boy, melted wings strapped to his back. He looks up at the endless abyss above your heads. Eyes full of regret too large for his age.", "You come across a woman with hollow eyes, white-knuckling a bouquet of roses. Despite years of wear and tear, you recognize her outfit as a wedding dress. 

", "You hear him before you see him. A lyreman plucking at his strings, lost in the rhythm of his own music. You wonder if he even knows you’re there.", "On your path, you meet a man with the armor and build of an esteemed warrior. Yet, despite this, the man swings his sword wildly at the air around him, hoarse throat shouting in rage. His days in war may be finished, but his fight is clearly not over.

It takes you a while to notice the arrow protruding from his heel.", "As you continue along your path, wandering souls below whisper incoherent fragments of memories from lives long forgotten.

As you listen to this cacophony, the siren song of the aimless, a thought begins to form. Learning from the voices the living world has deemed unworthy of listening to, you suddenly find yourself capable of that which you were previously not.", "As you continue along your path, you cannot help but witness the horrors around you, the suffering in this underworld that you and so many others are forced to call an eternal home. 

You will make the forces that be pay, whatever it may take to get there. For all those out there they have brought pain upon. How wonderful an idea.

But you are not that noble. This is your revenge alone. This thought, perhaps disturbing, gives you more comfort than the last. The idea of retribution satisfies you.", "As you continue along your path, your gaze falls to the mud beneath your feet. Your eyes latch onto the impression of a bootprint, unable to look away. There is nothing special about this print, in fact, it is one you’ve seen many times before.

It is one of your own.

Knowing you have been on this path before, so many more times than you could ever possibly hope to remember, you are filled with a sudden resolve, one goal in mind: This time will not be like the last."])

